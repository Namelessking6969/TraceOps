{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TraceOps",
  "version": "0.1.4",
  "identifier": "com.jake.traceops",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TraceOps",
        "width": 1200,
        "height": 750
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "RWS9Kxm0/7+INUEr2i5G+PhK8xclyVwVj9uJ0XLHOGRdRBsL0M2ugRgq",
      "endpoints": [
        "https://raw.githubusercontent.com/Namelessking6969/TraceOps/updates/latest.json"
      ]
    }
  }
}
